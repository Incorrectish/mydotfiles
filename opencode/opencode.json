{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "openai"
  ],
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4",
  "share": "disabled",
  "autoupdate": "notify",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "git push*": "ask",
      "git commit*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "rm *": "ask",
      "sudo *": "ask"
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "textVerbosity": "low",
    },
    "plan": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "high",
      "textVerbosity": "low",
    },
    "explore": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "textVerbosity": "low",
    },
    "general": {
      "model": "openai/gpt-5.4",
      "reasoningEffort": "low",
      "textVerbosity": "low",
    },
    "bypass-permissions": {
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "description": "High-trust mode that auto-allows edits, bash, web fetches, doom-loop checks, and external directory access.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "doom_loop": "ask",
        "external_directory": "ask"
      }
    }
  }
}
